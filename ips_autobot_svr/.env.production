# 生产环境示例：复制本文件为 .env（与 docker-compose 同目录）
# Docker Compose 会自动读取 .env 用于变量替换；勿将真实 .env 提交到 Git

# 必填：JWT 签名密钥（请使用长随机字符串）
JWT_SECRET=birwZWye4sPf0yPtHspUGsZa2u2TTlOtbirwZWye4sPf0yPtHspUGsZa2u2TTlOt

# 与 MySQL root 密码一致（docker-compose 中 mysql 与 app 共用此变量）
MYSQL_ROOT_PASSWORD=gR7iKWTvQLLqhhwn

# 可选：前端域名，多个用英文逗号分隔；不填则 CORS 允许任意来源（不推荐生产）
 CORS_ORIGIN=https://www.www.eiqimaimaia.xyz

# 可选
JWT_EXPIRES_IN=7d
# LOG_RETENTION_DAYS=30
