{
  "name": "openapi-to-md",
  "version": "1.1.1",
  "main": "dist/index.js",
  "bin": {
    "openapi-to-md": "dist/openapi-to-md.js"
  },
  "scripts": {
    "build": "tsc -b",
    "lint:fix": "eslint --fix src",
    "lint": "eslint src",
    "test": "vitest --coverage",
    "test:manual": "tsx src/openapi-to-md.ts test/tmp/api.github.com.yaml test/tmp/README.md",
    "test:sort": "tsx src/openapi-to-md.ts -s test/tmp/api.github.com.yaml test/tmp/README.md",
    "test:url": "tsx src/openapi-to-md.ts -s https://raw.githubusercontent.com/github/rest-api-description/main/descriptions/api.github.com/api.github.com.yaml test/tmp/README.md"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "^25.0.10",
    "@types/swagger2openapi": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "openapi-types": "^12.1.3",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "swagger2openapi": "^7.0.8",
    "yaml": "^2.8.2"
  },
  "description": "Convert OpenAPI format to Markdown",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoraKumo001/openapi-to-md.git"
  },
  "keywords": [
    "openapi",
    "swagger",
    "yaml",
    "json",
    "markdown"
  ],
  "author": "SoraKumo",
  "bugs": {
    "url": "https://github.com/SoraKumo001/openapi-to-md/issues"
  },
  "homepage": "https://github.com/SoraKumo001/openapi-to-md#readme"
}
